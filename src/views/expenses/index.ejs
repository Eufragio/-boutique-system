<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { title: 'Gastos | Boutique Panel' }) %>
</head>
<body>
    <div class="dashboard-wrapper">
        <%- include('../partials/sidebar') %>
        
        <main class="main-content bg-light-gray">
            <%- include('../partials/top_header') %>

            <div class="container-fluid px-4 pb-5">
                <div class="d-flex justify-content-between align-items-center mb-4 mt-2">
                    <h4 class="mb-0" style="font-family:'Playfair Display',serif; font-weight:700; color:var(--text-primary);"><i class="bi bi-receipt module-title-icon me-2"></i> Módulo de Gastos</h4>
                </div>
        
        <% if (success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success alert-dismissible fade show shadow-sm"><%= success_msg %> <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        <% } %>
        
        <div class="row">
            <div class="col-md-4">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white border-bottom-0 pt-3">
                        <h6 class="mb-0 fw-bold" style="color: var(--danger);"><i class="bi bi-dash-circle"></i> Registrar Salida de Dinero</h6>
                    </div>
                    <div class="card-body">
                        <form action="/gastos" method="POST">
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Descripción</label>
                                <input type="text" name="descripcion" class="form-control" placeholder="Ej: Pago de Luz, Almuerzo..." required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Monto (<%= typeof shop !== 'undefined' ? shop.moneda : 'S/' %>)</label>
                                <input type="number" name="monto" class="form-control" step="0.10" min="0.10" placeholder="0.00" required>
                            </div>
                            <button type="submit" class="btn btn-rose-danger w-100 fw-bold">Registrar Gasto</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white border-bottom-0 pt-3">
                        <h6 class="mb-0 fw-bold"><i class="bi bi-list-ul"></i> Últimos Movimientos</h6>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Fecha</th>
                                    <th>Descripción</th>
                                    <th>Registrado por</th>
                                    <th class="text-end">Monto</th>
                                    <th class="text-end">Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (gastos.length === 0) { %>
                                    <tr><td colspan="5" class="text-center py-4 text-muted">No hay gastos registrados hoy.</td></tr>
                                <% } else { %>
                                    <% gastos.forEach(g => { %>
                                        <tr>
                                            <td><small class="text-muted"><%= new Date(g.fecha).toLocaleTimeString('es-PE', {hour:'2-digit', minute:'2-digit'}) %></small></td>
                                            <td class="fw-bold text-dark"><%= g.descripcion %></td>
                                            <td><span class="badge bg-light text-dark border"><%= g.usuario_nombre %></span></td>
                                            <td class="text-end text-danger fw-bold">- <%= formatCurrency(g.monto) %></td>
                                            <td class="text-end">
                                                <% if (typeof userRol !== 'undefined' && userRol === 'admin') { %>
                                                    <form action="/gastos/eliminar/<%= g.id %>" method="POST" onsubmit="return confirm('¿Eliminar este gasto?');" class="d-inline">
                                                        <button type="submit" class="btn btn-sm btn-outline-secondary border-0"><i class="bi bi-trash"></i></button>
                                                    </form>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>