<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { title: 'Editar Cliente | Boutique Panel' }) %>
</head>
<body>
<div class="dashboard-wrapper">
    <%- include('../partials/sidebar') %>

    <main class="main-content">
        <%- include('../partials/top_header') %>

        <div class="container-fluid px-4 pb-5 mt-4">

            <!-- Encabezado -->
            <div class="d-flex align-items-center gap-3 mb-3">
                <a href="/clientes" class="btn btn-sm" style="background:#F8EFF2;color:var(--text-muted);border:1px solid #EEE4E1;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <h2 class="module-title mb-0">
                        <i class="bi bi-pencil-square module-title-icon"></i> Editar Cliente
                    </h2>
                    <p class="mb-0 small" style="color:var(--text-muted);padding-left:2px;"><%= cliente.nombre %></p>
                </div>
            </div>

            <hr class="boutique-divider mb-4">

            <div class="row justify-content-center">
                <div class="col-lg-7">
                    <div class="widget-card">
                        <div class="module-card-header" style="border-radius:16px 16px 0 0;">
                            <h6 class="module-title" style="font-size:0.95rem;">
                                <i class="bi bi-person-badge module-title-icon"></i> Datos del Cliente
                            </h6>
                            <!-- Avatar con inicial -->
                            <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--secondary));display:flex;align-items:center;justify-content:center;color:#fff;font-size:1rem;font-weight:700;">
                                <%= cliente.nombre.charAt(0).toUpperCase() %>
                            </div>
                        </div>

                        <div class="card-body p-4">
                            <form action="/clientes/editar/<%= cliente.id %>" method="POST">
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label class="form-label">Nombre Completo <span style="color:var(--danger);">*</span></label>
                                        <input type="text" name="nombre" class="form-control"
                                               value="<%= cliente.nombre %>" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">DNI / RUC</label>
                                        <input type="text" name="documento" class="form-control"
                                               value="<%= cliente.documento || '' %>">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">WhatsApp / Teléfono</label>
                                        <div class="input-group">
                                            <span class="input-group-text" style="background:#FBF7F5;border-color:#EEE4E1;">
                                                <i class="bi bi-whatsapp" style="color:var(--success);"></i>
                                            </span>
                                            <input type="text" name="telefono" class="form-control"
                                                   value="<%= cliente.telefono || '' %>">
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Correo Electrónico</label>
                                        <div class="input-group">
                                            <span class="input-group-text" style="background:#FBF7F5;border-color:#EEE4E1;">
                                                <i class="bi bi-envelope" style="color:var(--primary);"></i>
                                            </span>
                                            <input type="email" name="email" class="form-control"
                                                   value="<%= cliente.email || '' %>">
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Dirección</label>
                                        <div class="input-group">
                                            <span class="input-group-text" style="background:#FBF7F5;border-color:#EEE4E1;">
                                                <i class="bi bi-geo-alt" style="color:var(--secondary);"></i>
                                            </span>
                                            <input type="text" name="direccion" class="form-control"
                                                   value="<%= cliente.direccion || '' %>">
                                        </div>
                                    </div>
                                </div>

                                <hr class="boutique-divider my-4">

                                <div class="d-flex justify-content-between">
                                    <a href="/clientes/<%= cliente.id %>" class="btn btn-outline-rose">
                                        <i class="bi bi-arrow-left me-1"></i>Ver Perfil
                                    </a>
                                    <button type="submit" class="btn btn-boutique px-4">
                                        <i class="bi bi-save2 me-1"></i>Actualizar Datos
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>