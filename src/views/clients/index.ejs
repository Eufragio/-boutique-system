<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { title: 'Clientes | Boutique Panel' }) %>
</head>
<body>
<div class="dashboard-wrapper">
    <%- include('../partials/sidebar') %>

    <main class="main-content">
        <%- include('../partials/top_header') %>

        <div class="container-fluid px-4 pb-5 mt-4">

            <% if (success_msg && success_msg.length > 0) { %>
            <div class="alert alert-boutique-success alert-dismissible fade show d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-check-circle-fill fs-5"></i><span><%= success_msg %></span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
            <% } %>

            <!-- Encabezado -->
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h2 class="module-title mb-1">
                        <i class="bi bi-people-fill module-title-icon"></i> Clientes
                    </h2>
                    <p class="mb-0 small" style="color:var(--text-muted);padding-left:2px;">Gestiona tu base de compradores</p>
                </div>
                <a href="/clientes/crear" class="btn btn-boutique">
                    <i class="bi bi-person-plus-fill me-1"></i> Nuevo Cliente
                </a>
            </div>

            <hr class="boutique-divider mb-4">

            <!-- Tabla -->
            <div class="widget-card">
                <div class="widget-header-primary d-flex align-items-center justify-content-between" style="border-radius:16px 16px 0 0;">
                    <span class="fw-semibold" style="font-family:'Inter',sans-serif;letter-spacing:.4px;">
                        <i class="bi bi-list-ul me-2"></i>Directorio de Clientes
                    </span>
                    <span class="badge" style="background:rgba(255,255,255,0.2);font-size:0.72rem;font-weight:600;padding:4px 10px;border-radius:20px;">
                        <%= clientes.length %> registrado<%= clientes.length !== 1 ? 's' : '' %>
                    </span>
                </div>

                <div class="table-responsive">
                    <table class="boutique-table">
                        <thead>
                            <tr>
                                <th>Cliente</th>
                                <th>Documento</th>
                                <th>Contacto</th>
                                <th>Dirección</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (clientes.length === 0) { %>
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <i class="bi bi-person-x" style="font-size:2.5rem;color:var(--primary-light);display:block;margin-bottom:0.5rem;"></i>
                                    <span style="color:var(--text-muted);font-size:0.85rem;font-weight:600;text-transform:uppercase;letter-spacing:1px;">No hay clientes registrados</span>
                                </td>
                            </tr>
                            <% } else { %>
                            <% clientes.forEach(c => { %>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <!-- Avatar con inicial -->
                                        <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--secondary));display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.9rem;font-weight:700;flex-shrink:0;">
                                            <%= c.nombre.charAt(0).toUpperCase() %>
                                        </div>
                                        <span class="fw-bold" style="color:var(--primary);font-size:0.88rem;"><%= c.nombre %></span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge-rose"><%= c.documento || 'S/D' %></span>
                                </td>
                                <td>
                                    <% if (c.telefono) { %>
                                    <div class="d-flex align-items-center gap-1" style="font-size:0.83rem;">
                                        <i class="bi bi-whatsapp" style="color:var(--success);"></i>
                                        <span><%= c.telefono %></span>
                                    </div>
                                    <% } %>
                                    <% if (c.email) { %>
                                    <small style="color:var(--text-muted);font-size:0.75rem;"><i class="bi bi-envelope me-1"></i><%= c.email %></small>
                                    <% } %>
                                    <% if (!c.telefono && !c.email) { %>
                                    <span style="color:var(--text-muted);font-size:0.8rem;">—</span>
                                    <% } %>
                                </td>
                                <td><small style="color:var(--text-muted);"><%= c.direccion || '—' %></small></td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-1">
                                        <a href="/clientes/<%= c.id %>" class="btn btn-outline-rose btn-sm" title="Ver Perfil">
                                            <i class="bi bi-person-vcard"></i>
                                        </a>
                                        <% if (typeof userRol !== 'undefined' && userRol === 'admin') { %>
                                        <a href="/clientes/editar/<%= c.id %>" class="btn btn-sm btn-mauve" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form action="/clientes/eliminar/<%= c.id %>" method="POST" class="d-inline"
                                              onsubmit="return confirm('¿Eliminar a <%= c.nombre %>?');">
                                            <button type="submit" class="btn btn-sm btn-rose-danger" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>