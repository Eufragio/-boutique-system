<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { title: 'Perfil: ' + cliente.nombre + ' | Boutique Panel' }) %>
</head>
<body>
<div class="dashboard-wrapper">
    <%- include('../partials/sidebar') %>

    <main class="main-content">
        <%- include('../partials/top_header') %>

        <div class="container-fluid px-4 pb-5 mt-4">

            <!-- Encabezado de página -->
            <div class="d-flex align-items-center gap-3 mb-3">
                <a href="/clientes" class="btn btn-sm" style="background:#F8EFF2;color:var(--text-muted);border:1px solid #EEE4E1;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <h2 class="module-title mb-0">
                        <i class="bi bi-person-vcard module-title-icon"></i> Perfil del Cliente
                    </h2>
                    <p class="mb-0 small" style="color:var(--text-muted);padding-left:2px;">Historial y estadísticas de compra</p>
                </div>
            </div>

            <hr class="boutique-divider mb-4">

            <div class="row g-4">

                <!-- ===== COLUMNA IZQUIERDA: PERFIL ===== -->
                <div class="col-lg-4">
                    <div class="widget-card h-100">
                        <!-- Header con gradiente y avatar -->
                        <div class="widget-header-dark text-center" style="border-radius:16px 16px 0 0;padding:2rem 1.5rem 1.5rem;">
                            <div style="width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,var(--primary) 0%,var(--secondary) 100%);margin:0 auto 1rem;display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:700;color:#fff;border:3px solid rgba(201,132,122,0.4);box-shadow:0 4px 16px rgba(201,132,122,0.3);">
                                <%= cliente.nombre.charAt(0).toUpperCase() %>
                            </div>
                            <h5 style="font-family:'Playfair Display',serif;color:#fff;margin:0;font-weight:700;font-size:1.1rem;"><%= cliente.nombre %></h5>
                            <span class="badge-rose" style="margin-top:6px;display:inline-block;">
                                <%= cliente.documento || 'Sin documento' %>
                            </span>
                        </div>

                        <div class="card-body p-4">
                            <!-- Info de contacto -->
                            <div style="display:flex;flex-direction:column;gap:0.85rem;">
                                <div class="d-flex align-items-center gap-3">
                                    <div style="width:36px;height:36px;border-radius:10px;background:rgba(107,171,142,0.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                        <i class="bi bi-whatsapp" style="color:var(--success);font-size:1rem;"></i>
                                    </div>
                                    <div>
                                        <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">WhatsApp</div>
                                        <div style="font-size:0.85rem;color:var(--text-primary);font-weight:600;">
                                            <%= cliente.telefono || '—' %>
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center gap-3">
                                    <div style="width:36px;height:36px;border-radius:10px;background:rgba(201,132,122,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                        <i class="bi bi-envelope" style="color:var(--primary);font-size:1rem;"></i>
                                    </div>
                                    <div>
                                        <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Correo</div>
                                        <div style="font-size:0.82rem;color:var(--text-primary);font-weight:600;word-break:break-all;">
                                            <%= cliente.email || '—' %>
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center gap-3">
                                    <div style="width:36px;height:36px;border-radius:10px;background:rgba(155,127,166,0.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                        <i class="bi bi-geo-alt" style="color:var(--secondary);font-size:1rem;"></i>
                                    </div>
                                    <div>
                                        <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Dirección</div>
                                        <div style="font-size:0.82rem;color:var(--text-primary);font-weight:600;">
                                            <%= cliente.direccion || '—' %>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <hr class="boutique-divider my-3">

                            <!-- Botones de acción -->
                            <div class="d-grid gap-2">
                                <% if (cliente.telefono) { %>
                                <a href="https://wa.me/51<%= cliente.telefono %>" target="_blank" class="btn btn-green btn-sm fw-bold">
                                    <i class="bi bi-whatsapp me-1"></i> Contactar por WhatsApp
                                </a>
                                <% } %>
                                <% if (typeof userRol !== 'undefined' && userRol === 'admin') { %>
                                <a href="/clientes/editar/<%= cliente.id %>" class="btn btn-outline-rose btn-sm">
                                    <i class="bi bi-pencil-square me-1"></i> Editar Datos
                                </a>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ===== COLUMNA DERECHA: ESTADÍSTICAS + HISTORIAL ===== -->
                <div class="col-lg-8">
                    <!-- Widgets de estadísticas -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="widget-card mb-0" style="text-align:center;padding:1.4rem 1rem;">
                                <div style="width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,var(--primary),var(--primary-dark));margin:0 auto 0.75rem;display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-cash-stack" style="color:#fff;font-size:1.2rem;"></i>
                                </div>
                                <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:var(--text-muted);margin-bottom:4px;">Total Gastado</div>
                                <div style="font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;color:var(--primary);">
                                    <%= formatCurrency(cliente.total_gastado) %>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="widget-card mb-0" style="text-align:center;padding:1.4rem 1rem;">
                                <div style="width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,var(--secondary),var(--secondary-dark));margin:0 auto 0.75rem;display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-bag-check" style="color:#fff;font-size:1.2rem;"></i>
                                </div>
                                <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:var(--text-muted);margin-bottom:4px;">Compras</div>
                                <div style="font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;color:var(--secondary);">
                                    <%= cliente.compras_realizadas %>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="widget-card mb-0" style="text-align:center;padding:1.4rem 1rem;">
                                <div style="width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,var(--accent),#b8884e);margin:0 auto 0.75rem;display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-calendar-check" style="color:#fff;font-size:1.2rem;"></i>
                                </div>
                                <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:var(--text-muted);margin-bottom:4px;">Última Visita</div>
                                <div style="font-family:'Playfair Display',serif;font-size:1.15rem;font-weight:700;color:var(--accent);">
                                    <%= cliente.ultima_compra ? formatDateShort(cliente.ultima_compra) : 'N/A' %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Historial de compras -->
                    <div class="widget-card">
                        <div class="module-card-header" style="border-radius:16px 16px 0 0;">
                            <h6 class="module-title" style="font-size:0.95rem;">
                                <i class="bi bi-clock-history module-title-icon"></i> Historial de Compras
                            </h6>
                            <span class="badge-mauve"><%= historial.length %> venta<%= historial.length !== 1 ? 's' : '' %></span>
                        </div>

                        <div class="table-responsive">
                            <table class="boutique-table">
                                <thead>
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Estado</th>
                                        <th>Método</th>
                                        <th class="text-end">Total</th>
                                        <th class="text-end">Ver</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (historial.length === 0) { %>
                                    <tr>
                                        <td colspan="5" class="text-center py-5">
                                            <i class="bi bi-bag" style="font-size:2.5rem;color:var(--primary-light);display:block;margin-bottom:0.5rem;"></i>
                                            <span style="color:var(--text-muted);font-size:0.82rem;font-weight:600;text-transform:uppercase;letter-spacing:1px;">Aún no hay compras</span>
                                        </td>
                                    </tr>
                                    <% } else { %>
                                    <% historial.forEach(v => { %>
                                    <tr>
                                        <td style="font-size:0.83rem;"><%= formatDateLong(v.fecha) %></td>
                                        <td>
                                            <% if(v.estado === 'completado') { %>
                                            <span class="badge-rose" style="background:rgba(107,171,142,0.12);color:#3a6e52;">✓ Completado</span>
                                            <% } else { %>
                                            <span class="badge-rose" style="background:rgba(192,97,111,0.12);color:var(--danger);">✕ Anulado</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <span class="badge-champagne" style="font-size:0.7rem;"><%= v.metodo_pago %></span>
                                        </td>
                                        <td class="text-end fw-bold" style="color:var(--primary);font-size:0.9rem;">
                                            <%= formatCurrency(v.total) %>
                                        </td>
                                        <td class="text-end">
                                            <a href="/ventas/<%= v.id %>" class="btn btn-sm btn-outline-rose">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                    <% }) %>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div><!-- /widget-card historial -->

                </div>
            </div><!-- /row -->
        </div>
    </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>