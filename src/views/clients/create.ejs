<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { title: 'Nuevo Cliente | Boutique Panel' }) %>
</head>
<body>
<div class="dashboard-wrapper">
    <%- include('../partials/sidebar') %>

    <main class="main-content">
        <%- include('../partials/top_header') %>

        <div class="container-fluid px-4 pb-5 mt-4">

            <!-- Encabezado -->
            <div class="d-flex align-items-center gap-3 mb-3">
                <a href="/clientes" class="btn btn-sm" style="background:#F8EFF2;color:var(--text-muted);border:1px solid #EEE4E1;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <h2 class="module-title mb-0">
                        <i class="bi bi-person-plus-fill module-title-icon"></i> Nuevo Cliente
                    </h2>
                </div>
            </div>

            <hr class="boutique-divider mb-4">

            <div class="row justify-content-center">
                <div class="col-lg-7">
                    <div class="widget-card">
                        <div class="widget-header-primary" style="border-radius:16px 16px 0 0;">
                            <span class="fw-semibold" style="font-family:'Inter',sans-serif;">
                                <i class="bi bi-person-badge me-2"></i>Datos del Cliente
                            </span>
                        </div>
                        <div class="card-body p-4">
                            <form action="/clientes" method="POST">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Nombre Completo <span style="color:var(--danger);">*</span></label>
                                        <input type="text" name="nombre" class="form-control" required placeholder="Ej: María García">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">DNI / RUC <span style="color:var(--danger);">*</span></label>
                                        <input type="text" name="documento" class="form-control" required placeholder="Ej: 12345678">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Teléfono / Celular</label>
                                        <div class="input-group">
                                            <span class="input-group-text" style="background:#FBF7F5;border-color:#EEE4E1;">
                                                <i class="bi bi-whatsapp" style="color:var(--success);"></i>
                                            </span>
                                            <input type="text" name="telefono" class="form-control" placeholder="999 999 999">
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Correo Electrónico</label>
                                        <div class="input-group">
                                            <span class="input-group-text" style="background:#FBF7F5;border-color:#EEE4E1;">
                                                <i class="bi bi-envelope" style="color:var(--primary);"></i>
                                            </span>
                                            <input type="email" name="email" class="form-control" placeholder="correo@ejemplo.com">
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">Dirección</label>
                                        <div class="input-group">
                                            <span class="input-group-text" style="background:#FBF7F5;border-color:#EEE4E1;">
                                                <i class="bi bi-geo-alt" style="color:var(--secondary);"></i>
                                            </span>
                                            <input type="text" name="direccion" class="form-control" placeholder="Av. Principal 123, Lima">
                                        </div>
                                    </div>
                                </div>

                                <hr class="boutique-divider my-4">

                                <div class="d-flex justify-content-end gap-2">
                                    <a href="/clientes" class="btn btn-outline-rose">
                                        <i class="bi bi-x-lg me-1"></i>Cancelar
                                    </a>
                                    <button type="submit" class="btn btn-boutique px-4">
                                        <i class="bi bi-person-check-fill me-1"></i>Guardar Cliente
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>