<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { title: 'Mi Perfil | Boutique Panel' }) %>
</head>
<body>
    <div class="dashboard-wrapper">
        <%- include('../partials/sidebar') %>
        
        <main class="main-content bg-light-gray">
            <%- include('../partials/top_header') %>

            <div class="container-fluid px-4 pb-5 mt-3">
        
        <div class="row justify-content-center">
            
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body text-center">
                        <div class="mb-3">
                            <div class="d-inline-flex align-items-center justify-content-center bg-primary text-white rounded-circle fs-1 shadow-sm" style="width: 80px; height: 80px;">
                                <i class="bi bi-person"></i>
                            </div>
                        </div>
                        <h4 class="fw-bold mb-0"><%= usuario.nombre %></h4>
                        <div class="text-muted mb-3"><%= usuario.email %></div>
                        
                        <span class="badge <%= usuario.rol === 'admin' ? 'bg-warning text-dark' : 'bg-secondary' %>">
                            ROL: <%= usuario.rol.toUpperCase() %>
                        </span>
                        
                        <div class="mt-4 alert alert-info small">
                            <i class="bi bi-info-circle"></i> Para cambiar tu nombre o rol, contacta al administrador del sistema.
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white border-bottom-0 pt-3">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-shield-lock"></i> Seguridad</h5>
                    </div>
                    <div class="card-body">
                        
                        <% if (success_msg && success_msg.length > 0) { %>
                            <div class="alert alert-success"><%= success_msg %></div>
                        <% } %>
                        <% if (error_msg && error_msg.length > 0) { %>
                            <div class="alert alert-danger"><%= error_msg %></div>
                        <% } %>

                        <form action="/perfil/password" method="POST">
                            
                            <div class="mb-3">
                                <label class="form-label fw-bold">Contraseña Actual</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-key"></i></span>
                                    <input type="password" name="currentPassword" class="form-control" required placeholder="Ingresa tu clave actual">
                                </div>
                            </div>

                            <hr>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Nueva Contraseña</label>
                                <input type="password" name="newPassword" class="form-control" required minlength="4">
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Confirmar Nueva Contraseña</label>
                                <input type="password" name="confirmPassword" class="form-control" required minlength="4">
                            </div>

                            <button type="submit" class="btn btn-primary w-100 fw-bold mt-2">
                                Actualizar Contraseña
                            </button>
                        </form>
                    </div>
                </div>
            </div>

        </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>