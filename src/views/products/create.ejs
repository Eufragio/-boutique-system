<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { title: 'Nuevo Producto | Boutique Panel' }) %>
</head>
<body>
<div class="dashboard-wrapper">
    <%- include('../partials/sidebar') %>

    <main class="main-content">
        <%- include('../partials/top_header') %>

        <div class="container-fluid px-4 pb-5 mt-4">

            <!-- Encabezado -->
            <div class="d-flex align-items-center gap-3 mb-3">
                <a href="/productos" class="btn btn-sm" style="background:#F8EFF2;color:var(--text-muted);border:1px solid #EEE4E1;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <h2 class="module-title mb-0">
                        <i class="bi bi-box-seam-fill module-title-icon"></i> Nuevo Producto
                    </h2>
                </div>
            </div>

            <hr class="boutique-divider mb-4">

            <div class="row justify-content-center">
                <div class="col-lg-9">
                    <% if (error_msg && error_msg.length > 0) { %>
                    <div class="alert alert-boutique-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-4">
                        <i class="bi bi-exclamation-triangle-fill fs-5"></i><span><%= error_msg %></span>
                        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                    </div>
                    <% } %>

                    <div class="widget-card">
                        <div class="widget-header-primary" style="border-radius:16px 16px 0 0;">
                            <span class="fw-semibold" style="font-family:'Inter',sans-serif;">
                                <i class="bi bi-tag-fill me-2"></i>Ficha de Producto
                            </span>
                        </div>
                        <div class="card-body p-4">
                            <form action="/productos" method="POST" enctype="multipart/form-data">
                                <div class="row g-4">
                                    <!-- Columna principal -->
                                    <div class="col-md-7">
                                        <div class="mb-4">
                                            <label class="form-label">Nombre del Producto <span style="color:var(--danger);">*</span></label>
                                            <input type="text" name="nombre" class="form-control form-control-lg" style="font-size:0.95rem;" placeholder="Ej: Camisa Marga Larga Seda" required autofocus>
                                        </div>

                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label">Código de Barras</label>
                                                <div class="input-group">
                                                    <span class="input-group-text" style="background:#FBF7F5;border-color:#EEE4E1;"><i class="bi bi-upc"></i></span>
                                                    <input type="text" name="codigo" class="form-control" placeholder="Escanea o escribe">
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Categoría</label>
                                                <select name="categoria_id" class="form-select">
                                                    <option value="">-- Sin categoría --</option>
                                                    <% categorias.forEach(cat => { %>
                                                    <option value="<%= cat.id %>"><%= cat.nombre %></option>
                                                    <% }) %>
                                                </select>
                                            </div>
                                        </div>

                                        <div class="mt-4 p-3 rounded-4" style="background:#FBF7F5;border:1px solid #F5EBF0;">
                                            <h6 class="mb-3" style="font-family:'Inter',sans-serif;font-size:0.75rem;font-weight:700;text-transform:uppercase;color:var(--text-muted);letter-spacing:1px;">
                                                <i class="bi bi-currency-dollar me-1"></i> Precios y Costos
                                            </h6>
                                            <div class="row g-3">
                                                <div class="col-md-6">
                                                    <label class="form-label text-success" style="font-weight:700;">Precio de Venta</label>
                                                    <div class="input-group">
                                                        <span class="input-group-text bg-white" style="color:var(--success);border-color:#EEE4E1;"><%= typeof shop !== 'undefined' ? shop.moneda : 'S/' %></span>
                                                        <input type="number" name="precio" class="form-control fw-bold text-success" style="border-color:#EEE4E1;" step="0.10" min="0" required placeholder="0.00">
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label" style="color:var(--danger);font-weight:600;">Costo de Compra</label>
                                                    <div class="input-group">
                                                        <span class="input-group-text bg-white" style="border-color:#EEE4E1;"><%= typeof shop !== 'undefined' ? shop.moneda : 'S/' %></span>
                                                        <input type="number" name="precio_compra" class="form-control" style="border-color:#EEE4E1;" step="0.10" min="0" placeholder="0.00">
                                                    </div>
                                                    <div class="form-text" style="font-size:0.65rem;">Base para reporte de rentabilidad.</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Columna secundaria (Stock e Imagen) -->
                                    <div class="col-md-5">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Stock Inicial <span style="color:var(--danger);">*</span></label>
                                            <input type="number" name="stock" class="form-control text-center" style="font-size:1.1rem;font-weight:700;color:var(--primary);" value="0" min="0" required>
                                        </div>
                                        <div class="mb-4">
                                            <label class="form-label text-muted">Stock Mínimo (Alerta crítica)</label>
                                            <input type="number" name="stock_minimo" class="form-control text-center text-muted" value="5" min="1">
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">Imagen del Producto</label>
                                            <input type="file" name="imagen" class="form-control form-control-sm mb-2" accept="image/*" onchange="previewImage(this)">
                                            <div class="rounded-4" style="height:140px;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#FBF7F5,#F8EFF2);border:1px dashed #D4A574;overflow:hidden;">
                                                <img id="imgPreview" src="#" alt="Vista previa" style="max-width:100%;max-height:100%;object-fit:contain;padding:5px;display:none;">
                                                <div id="imgPlaceholder" class="text-center" style="color:var(--primary-light);">
                                                    <i class="bi bi-image" style="font-size:2rem;display:block;margin-bottom:5px;"></i>
                                                    <span style="font-size:0.7rem;font-weight:600;text-transform:uppercase;">Sin imagen</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <hr class="boutique-divider my-4">

                                <div class="d-flex justify-content-end gap-2">
                                    <a href="/productos" class="btn btn-outline-rose">
                                        <i class="bi bi-x-lg me-1"></i>Cancelar
                                    </a>
                                    <button type="submit" class="btn btn-boutique px-4">
                                        <i class="bi bi-box-arrow-in-down me-1"></i>Registro Inicial Completo
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<script>
    function previewImage(input) {
        const preview = document.getElementById('imgPreview');
        const placeholder = document.getElementById('imgPlaceholder');

        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result;
                preview.style.display = 'block';
                placeholder.style.display = 'none';
            }
            reader.readAsDataURL(input.files[0]);
        } else {
            preview.src = '#';
            preview.style.display = 'none';
            placeholder.style.display = 'block';
        }
    }
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>