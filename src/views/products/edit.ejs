<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { title: 'Editar Producto | Boutique Panel' }) %>
</head>
<body>
<div class="dashboard-wrapper">
    <%- include('../partials/sidebar') %>

    <main class="main-content">
        <%- include('../partials/top_header') %>

        <div class="container-fluid px-4 pb-5 mt-4">

            <!-- Encabezado -->
            <div class="d-flex align-items-center gap-3 mb-3">
                <a href="/productos" class="btn btn-sm" style="background:#F8EFF2;color:var(--text-muted);border:1px solid #EEE4E1;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <h2 class="module-title mb-0">
                        <i class="bi bi-pencil-square module-title-icon"></i> Editar Producto
                    </h2>
                    <p class="mb-0 small" style="color:var(--text-muted);padding-left:2px;"><%= producto.nombre %></p>
                </div>
            </div>

            <hr class="boutique-divider mb-4">

            <div class="row justify-content-center">
                <div class="col-lg-9">
                    <div class="widget-card">
                        <div class="module-card-header" style="border-radius:16px 16px 0 0;">
                            <h6 class="module-title" style="font-size:0.95rem;">
                                <i class="bi bi-tags module-title-icon"></i> Información del Producto
                            </h6>
                            <span class="badge-champagne"><i class="bi bi-upc me-1"></i><%= producto.codigo_barras || 'S/C' %></span>
                        </div>
                        <div class="card-body p-4">

                            <form action="/productos/editar/<%= producto.id %>" method="POST" enctype="multipart/form-data">
                                <div class="row g-4">

                                    <!-- Columna principal -->
                                    <div class="col-md-7">
                                        <div class="mb-4">
                                            <label class="form-label">Nombre del Producto <span style="color:var(--danger);">*</span></label>
                                            <input type="text" name="nombre" class="form-control form-control-lg" style="font-size:0.95rem;" value="<%= producto.nombre %>" required>
                                        </div>

                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label text-muted">Código de Barras</label>
                                                <div class="input-group">
                                                    <span class="input-group-text" style="background:#FBF7F5;border-color:#EEE4E1;"><i class="bi bi-upc"></i></span>
                                                    <input type="text" name="codigo_barras" class="form-control" value="<%= producto.codigo_barras %>">
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label text-muted">Categoría</label>
                                                <select name="categoria_id" class="form-select">
                                                    <option value="">-- Sin Categoría --</option>
                                                    <% categorias.forEach(c => { %>
                                                    <option value="<%= c.id %>" <%= producto.categoria_id === c.id ? 'selected' : '' %>>
                                                        <%= c.nombre %>
                                                    </option>
                                                    <% }) %>
                                                </select>
                                            </div>
                                        </div>

                                        <div class="mt-4 p-3 rounded-4 border" style="background:#FBF7F5;border-color:#EEE4E1;">
                                            <h6 class="mb-3" style="font-family:'Inter',sans-serif;font-size:0.75rem;font-weight:700;text-transform:uppercase;color:var(--text-muted);letter-spacing:1px;">
                                                <i class="bi bi-currency-dollar me-1"></i> Precios y Costos
                                            </h6>
                                            <div class="row g-3">
                                                <div class="col-md-6">
                                                    <label class="form-label text-success" style="font-weight:700;">Precio de Venta</label>
                                                    <div class="input-group">
                                                        <span class="input-group-text bg-white" style="color:var(--success);border-color:#EEE4E1;"><%= typeof shop !== 'undefined' ? shop.moneda : 'S/' %></span>
                                                        <input type="number" name="precio_venta" class="form-control fw-bold text-success" style="border-color:#EEE4E1;" step="0.01" value="<%= producto.precio_venta %>" required>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label text-danger" style="font-weight:600;">Costo de Compra</label>
                                                    <div class="input-group">
                                                        <span class="input-group-text bg-white" style="border-color:#EEE4E1;"><%= typeof shop !== 'undefined' ? shop.moneda : 'S/' %></span>
                                                        <input type="number" name="precio_compra" class="form-control" style="border-color:#EEE4E1;" step="0.01" value="<%= producto.precio_compra %>">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Columna secundaria -->
                                    <div class="col-md-5">
                                        <div class="mb-4">
                                            <label class="form-label fw-bold">Stock Actual <span style="color:var(--danger);">*</span></label>
                                            <input type="number" name="stock_actual" class="form-control text-center text-primary" style="font-size:1.1rem;font-weight:700;" value="<%= producto.stock_actual %>" required>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Imagen del Producto</label>
                                            <div class="d-flex flex-column gap-3">
                                                <div class="rounded-4" style="height:140px;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#FBF7F5,#F8EFF2);border:1px solid #EEE4E1;overflow:hidden;position:relative;">
                                                    <% if(producto.imagen_url) { %>
                                                    <img src="<%= producto.imagen_url %>" id="imgPreview" style="max-width:100%;max-height:100%;object-fit:contain;padding:5px;">
                                                    <div id="iconPlaceholder" class="d-none"></div>
                                                    <% } else { %>
                                                    <i class="bi bi-image" id="iconPlaceholder" style="font-size:2.5rem;color:var(--primary-light);"></i>
                                                    <img src="" id="imgPreview" class="d-none" style="max-width:100%;max-height:100%;object-fit:contain;padding:5px;">
                                                    <% } %>
                                                </div>

                                                <div>
                                                    <input type="file" name="imagen" class="form-control form-control-sm" accept="image/*" onchange="previewImage(this)">
                                                    <div class="form-text mt-1" style="font-size:0.65rem;">Sube un archivo si deseas cambiar la imagen actual (1x1 recomedado).</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>

                                <hr class="boutique-divider my-4">

                                <div class="d-flex justify-content-end gap-2">
                                    <a href="/productos" class="btn btn-outline-rose">
                                        <i class="bi bi-x-lg me-1"></i>Cancelar
                                    </a>
                                    <button type="submit" class="btn btn-boutique px-4">
                                        <i class="bi bi-save2 me-1"></i>Actualizar Detalles
                                    </button>
                                </div>

                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<script>
    function previewImage(input) {
        const preview = document.getElementById('imgPreview');
        const icon = document.getElementById('iconPlaceholder');

        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result;
                preview.classList.remove('d-none');
                if(icon) icon.classList.add('d-none');
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>