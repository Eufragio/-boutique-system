<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { title: 'Kardex: ' + producto.nombre + ' | Boutique Panel' }) %>
</head>
<body>
<div class="dashboard-wrapper">
    <%- include('../partials/sidebar') %>

    <main class="main-content">
        <%- include('../partials/top_header') %>

        <div class="container-fluid px-4 pb-5 mt-4">

            <!-- Encabezado -->
            <div class="d-flex align-items-center gap-3 mb-3">
                <a href="/productos" class="btn btn-sm" style="background:#F8EFF2;color:var(--text-muted);border:1px solid #EEE4E1;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <h2 class="module-title mb-0">
                        <i class="bi bi-clipboard2-data module-title-icon"></i> Kardex de Producto
                    </h2>
                    <p class="mb-0 small" style="color:var(--text-muted);padding-left:2px;">Historial de movimientos y stock</p>
                </div>
            </div>

            <hr class="boutique-divider mb-4">

            <div class="row g-4">
                <!-- Tarjeta Resumen del Producto -->
                <div class="col-lg-4">
                    <div class="widget-card h-100">
                        <div class="widget-header-dark text-center" style="border-radius:16px 16px 0 0;padding:2rem 1.5rem 1.5rem;">
                            <div style="width:80px;height:80px;border-radius:16px;background:#fff;margin:0 auto 1rem;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(201,132,122,0.3);overflow:hidden;padding:5px;">
                                <% if (producto.imagen_url) { %>
                                <img src="<%= producto.imagen_url %>" style="max-width:100%;max-height:100%;object-fit:contain;">
                                <% } else { %>
                                <i class="bi bi-image" style="font-size:2.5rem;color:var(--primary-light);"></i>
                                <% } %>
                            </div>
                            <h5 style="font-family:'Playfair Display',serif;color:#fff;margin:0;font-weight:700;font-size:1.1rem;line-height:1.3;"><%= producto.nombre %></h5>
                            <div class="mt-2">
                                <span class="badge-champagne" style="font-size:0.65rem;background:rgba(255,255,255,0.2);color:#fff;border:none;"><i class="bi bi-upc me-1"></i><%= producto.codigo_barras || 'S/C' %></span>
                            </div>
                        </div>

                        <div class="card-body p-4 text-center">
                            <h6 style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);margin-bottom:0.5rem;">Stock Disponible</h6>
                            
                            <% const stockBajo = producto.stock_actual <= (producto.stock_minimo || 5); %>
                            <div style="font-family:'Playfair Display',serif;font-size:3rem;font-weight:700;line-height:1;margin-bottom:0.5rem;color:<%= producto.stock_actual === 0 ? 'var(--danger)' : (stockBajo ? '#7A5C2E' : 'var(--success)') %>">
                                <%= producto.stock_actual %>
                            </div>
                            
                            <span class="badge-rose" style="<%= producto.stock_actual === 0 ? 'background:rgba(192,97,111,0.15);color:var(--danger);' : (stockBajo ? 'background:rgba(212,165,116,0.18);color:#7A5C2E;' : 'background:rgba(107,171,142,0.12);color:#3a6e52;') %>">
                                <%= producto.stock_actual === 0 ? 'Agotado' : (stockBajo ? 'Stock Bajo' : 'Stock Óptimo') %>
                            </span>

                            <hr class="boutique-divider my-4">

                            <div class="d-flex justify-content-between text-start mb-2">
                                <span style="font-size:0.8rem;color:var(--text-muted);font-weight:600;">Categoría</span>
                                <span class="fw-bold" style="font-size:0.85rem;color:var(--text-primary);"><%= producto.categoria_nombre || 'General' %></span>
                            </div>
                            <div class="d-flex justify-content-between text-start mb-2">
                                <span style="font-size:0.8rem;color:var(--text-muted);font-weight:600;">Precio de Venta</span>
                                <span class="fw-bold" style="font-size:0.85rem;color:var(--primary);"><%= formatCurrency(producto.precio_venta) %></span>
                            </div>
                            <% if (typeof userRol !== 'undefined' && userRol === 'admin') { %>
                            <div class="d-flex justify-content-between text-start">
                                <span style="font-size:0.8rem;color:var(--text-muted);font-weight:600;">Costo Promedio</span>
                                <span class="fw-bold" style="font-size:0.85rem;color:var(--danger);"><%= formatCurrency(producto.precio_compra) %></span>
                            </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- Historial de Movimientos -->
                <div class="col-lg-8">
                    <div class="widget-card h-100">
                        <div class="module-card-header" style="border-radius:16px 16px 0 0;">
                            <h6 class="module-title" style="font-size:0.95rem;">
                                <i class="bi bi-clock-history module-title-icon"></i> Registro de Operaciones
                            </h6>
                            <span class="badge-mauve"><%= movimientos.length %> movs.</span>
                        </div>

                        <div class="table-responsive">
                            <table class="boutique-table">
                                <thead>
                                    <tr>
                                        <th>Fecha y Hora</th>
                                        <th>Operación</th>
                                        <th>Referencia</th>
                                        <th>Entidad</th>
                                        <th class="text-center">Ingreso</th>
                                        <th class="text-center">Salida</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (movimientos.length === 0) { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-5">
                                            <i class="bi bi-activity" style="font-size:2.5rem;color:var(--primary-light);display:block;margin-bottom:0.5rem;"></i>
                                            <span style="color:var(--text-muted);font-size:0.82rem;font-weight:600;text-transform:uppercase;letter-spacing:1px;">Sin movimientos registrados</span>
                                        </td>
                                    </tr>
                                    <% } else { %>
                                    <% movimientos.forEach(m => { %>
                                    <tr>
                                        <td>
                                            <div class="fw-bold" style="font-size:0.83rem;color:var(--text-primary);"><%= formatDateShort(m.fecha) %></div>
                                            <small style="color:var(--text-muted);font-size:0.7rem;"><%= new Date(m.fecha).toLocaleTimeString('es-PE', {hour:'2-digit', minute:'2-digit'}) %></small>
                                        </td>
                                        <td>
                                            <% if (m.tipo_movimiento === 'COMPRA') { %>
                                            <span class="badge-rose" style="background:rgba(107,171,142,0.12);color:#3a6e52;font-size:0.65rem;">
                                                <i class="bi bi-arrow-down-left me-1"></i> COMPRA
                                            </span>
                                            <% } else { %>
                                            <span class="badge-rose" style="background:rgba(192,97,111,0.12);color:var(--danger);font-size:0.65rem;">
                                                <i class="bi bi-arrow-up-right me-1"></i> VENTA
                                            </span>
                                            <% } %>
                                        </td>
                                        <td><span style="font-family:'Inter',monospace;font-size:0.8rem;color:var(--text-muted);"><%= m.documento %></span></td>
                                        <td><div style="font-size:0.8rem;max-width:150px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= m.entidad %></div></td>
                                        
                                        <td class="text-center">
                                            <% if (m.entrada > 0) { %>
                                            <span style="font-weight:800;color:var(--success);font-size:0.95rem;">+<%= m.entrada %></span>
                                            <% } else { %>
                                            <span style="color:#EEE4E1;">-</span>
                                            <% } %>
                                        </td>
                                        
                                        <td class="text-center">
                                            <% if (m.salida > 0) { %>
                                            <span style="font-weight:800;color:var(--danger);font-size:0.95rem;">-<%= m.salida %></span>
                                            <% } else { %>
                                            <span style="color:#EEE4E1;">-</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>