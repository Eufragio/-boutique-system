<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Abrir Caja | Boutique System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="height: 100vh;">
    <!-- Plantilla base boutique con Sidebar y Header -->
    <%- include('../partials/head', { title: 'Abrir Caja | Boutique Panel' }) %>
</head>
<body>

    <div class="dashboard-wrapper">
        <%- include('../partials/sidebar') %>

        <main class="main-content">
            <%- include('../partials/top_header') %>

            <div class="container-fluid px-4 pb-5 mt-4 d-flex align-items-center justify-content-center" style="min-height: calc(100vh - 120px);">
                
                <div class="widget-card" style="width: 100%; max-width: 480px;">
                    <div class="widget-header-dark text-center py-4" style="border-radius:16px 16px 0 0;">
                        <div class="bg-white text-dark rounded-circle d-inline-flex align-items-center justify-content-center mb-2 shadow-sm" style="width:50px; height:50px;">
                            <i class="bi bi-wallet2 fs-4" style="color:var(--primary);"></i>
                        </div>
                        <h4 class="mb-0 fw-bold" style="font-family:'Playfair Display',serif; letter-spacing:0.5px;">Apertura de Caja</h4>
                    </div>
                    
                    <div class="card-body p-4 p-md-5">
                        
                        <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
                            <div class="alert alert-boutique-danger d-flex align-items-center mb-4">
                                <i class="bi bi-exclamation-octagon-fill me-2 fs-5"></i>
                                <div><%= error_msg %></div>
                            </div>
                        <% } %>

                        <div class="text-center mb-4 pb-2" style="border-bottom:1px dashed #E2D1D8;">
                            <p class="text-muted mb-1" style="font-size:0.95rem;">
                                ¡Hola, <strong class="text-uppercase" style="color:var(--text-primary); letter-spacing:1px;"><%= typeof user !== 'undefined' ? user : 'Cajero' %></strong>! 
                            </p>
                            <p class="text-muted small" style="font-size:0.8rem;">Ingresa el dinero en efectivo que tienes como base para comenzar el turno.</p>
                        </div>

                        <form action="/caja/apertura" method="POST">
                            <div class="mb-4">
                                <label class="form-label text-muted small fw-bold text-uppercase">Fondo de Caja (Sencillo Inicial)</label>
                                <div class="input-group input-group-lg shadow-sm rounded-3 overflow-hidden" style="border: 1px solid var(--primary-light);">
                                    <span class="input-group-text bg-white border-0 fw-bold text-muted ps-3">S/</span>
                                    <input type="number" name="monto_inicial" id="monto_inicial_input" class="form-control border-0 px-2 fw-semibold" step="0.10" value="0.00" required autofocus style="color:var(--primary-dark);">
                                </div>
                                <div class="form-text mt-2" style="font-size:0.75rem;"><i class="bi bi-info-circle me-1"></i>Cuenta detalladamente monedas y billetes presentes físicamente.</div>
                            </div>

                            <div class="d-flex flex-column gap-3 mt-4 pt-2">
                                <button type="submit" class="btn btn-boutique btn-lg w-100 py-3 shadow-sm rounded-3 fw-bold d-flex align-items-center justify-content-center" style="letter-spacing:1px;">
                                    <i class="bi bi-check2-circle fs-5 me-2"></i> INICIAR TURNO DE VENTA
                                </button>
                                <a href="/" class="btn btn-light border w-100 py-2 rounded-3 text-muted fw-semibold">
                                    <i class="bi bi-arrow-left me-1"></i> Regresar al Menú
                                </a>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </main>
    </div>
    
    <!-- Auto-select text on focus -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const input = document.getElementById('monto_inicial_input');
            if(input) {
                input.addEventListener('focus', function() { this.select(); });
            }
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>