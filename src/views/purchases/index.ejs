<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { title: 'Compras | Boutique Panel' }) %>
</head>
<body>
<div class="dashboard-wrapper">
    <%- include('../partials/sidebar') %>

    <main class="main-content">
        <%- include('../partials/top_header') %>

        <div class="container-fluid px-4 pb-5 mt-4">

            <!-- Encabezado -->
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="module-title mb-1">
                        <i class="bi bi-basket2-fill module-title-icon"></i> Compras y Abastecimiento
                    </h2>
                    <p class="mb-0 small" style="color:var(--text-muted);padding-left:2px;">Registro de facturas y órdenes de proveedores</p>
                </div>
                <a href="/compras/nueva" class="btn btn-boutique">
                    <i class="bi bi-cart-plus me-1"></i> Registrar Compra
                </a>
            </div>

            <hr class="boutique-divider mb-4">

            <div class="widget-card">
                <div class="widget-header-dark" style="border-radius:16px 16px 0 0;">
                    <span class="fw-semibold" style="font-family:'Inter',sans-serif;letter-spacing:.4px;">
                        <i class="bi bi-receipt me-2"></i>Historial de Ingresos de Mercadería
                    </span>
                </div>

                <div class="table-responsive">
                    <table class="boutique-table">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Proveedor</th>
                                <th>Comprobante</th>
                                <th>Total</th>
                                <th>Estado</th>
                                <th class="text-end">Detalles</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (compras.length === 0) { %>
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <i class="bi bi-bag-x" style="font-size:2.5rem;color:var(--primary-light);display:block;margin-bottom:0.5rem;"></i>
                                    <span style="color:var(--text-muted);font-size:0.85rem;font-weight:600;text-transform:uppercase;letter-spacing:1px;">No hay compras registradas</span>
                                </td>
                            </tr>
                            <% } else { %>
                            <% compras.forEach(c => { %>
                            <tr>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold" style="color:var(--text-primary);font-size:0.85rem;"><%= formatDateShort(c.fecha) %></span>
                                        <small style="color:var(--text-muted);font-size:0.7rem;"><%= new Date(c.fecha).toLocaleTimeString('es-PE', {hour:'2-digit', minute:'2-digit'}) %></small>
                                    </div>
                                </td>
                                <td>
                                    <span style="font-weight:600;color:var(--text-primary);font-size:0.9rem;"><%= c.proveedor_nombre %></span>
                                </td>
                                <td>
                                    <span class="badge-champagne" style="font-family:'Inter',monospace;font-size:0.75rem;">
                                        <i class="bi bi-file-earmark-text me-1"></i><%= c.tipo_comprobante %> <%= c.numero_comprobante %>
                                    </span>
                                </td>
                                <td>
                                    <span style="font-weight:800;color:var(--primary);font-size:0.95rem;font-family:'Playfair Display',serif;"><%= formatCurrency(c.total) %></span>
                                </td>
                                <td>
                                    <span class="badge-rose" style="background:rgba(107,171,142,0.12);color:#3a6e52;font-size:0.7rem;">
                                        <i class="bi bi-check-circle-fill me-1"></i>Completado
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a href="/compras/<%= c.id %>" class="btn btn-sm btn-mauve" title="Ver Detalles">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                            <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>