<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { title: 'Ventas | Boutique Panel' }) %>
    <style>
        .table-anulada {
            background-color: #ffebe9 !important;
            color: #a82824;
            opacity: 0.8;
        }
    </style>
</head>
<body>
    <div class="dashboard-wrapper">
        <%- include('../partials/sidebar') %>
        
        <main class="main-content bg-light-gray">
            <%- include('../partials/top_header') %>

            <div class="container-fluid px-4 pb-5">
                <div class="d-flex justify-content-between align-items-center mb-4 mt-2">
                    <div>
                        <h4 class="mb-0" style="font-family:'Playfair Display',serif; font-weight:700; color:var(--text-primary);"><i class="bi bi-bag-check-fill module-title-icon me-2"></i> Historial de Ventas</h4>
                        <small style="color: var(--text-muted);">Gestiona tus transacciones y reportes.</small>
                    </div>
                    <a href="/ventas/nueva" class="btn btn-boutique btn-sm fw-bold shadow-sm">
                        <i class="bi bi-plus-lg"></i> Nueva Venta
                    </a>
                </div>
        
        <% if (success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 border-start border-success border-5">
                <i class="bi bi-check-circle-fill me-2"></i> <%= success_msg %> 
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>
        <% if (error_msg && error_msg.length > 0) { %>
            <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 border-start border-danger border-5">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> <%= error_msg %> 
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <form method="GET" class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <!-- Moved to top -->
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-muted">Desde:</label>
                        <input type="date" name="fechaInicio" class="form-control" value="<%= filtros.fechaInicio || '' %>">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-muted">Hasta:</label>
                        <input type="date" name="fechaFin" class="form-control" value="<%= filtros.fechaFin || '' %>">
                    </div>
                    <div class="col-md-2">
                        <div class="d-flex gap-2">
                            <button type="submit" formaction="/ventas" class="btn btn-boutique flex-grow-1 shadow-sm" title="Buscar / Filtrar">
                                <i class="bi bi-search"></i>
                            </button>
                            <button type="submit" formaction="/ventas/exportar" class="btn btn-mauve flex-grow-1 shadow-sm" title="Descargar Excel">
                                <i class="bi bi-file-earmark-excel-fill"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>#ID</th>
                                <th>Fecha y Hora</th>
                                <th>Cliente</th>
                                <th>Método Pago</th>
                                <th>Total</th>
                                <th>Estado</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (ventas.length === 0) { %>
                                <tr>
                                    <td colspan="7" class="text-center py-5 text-muted">
                                        <i class="bi bi-inbox fs-1 d-block mb-2"></i> No se encontraron ventas.
                                    </td>
                                </tr>
                            <% } else { %>
                                <% ventas.forEach(v => { %>
                                    <tr class="<%= v.estado === 'anulado' ? 'table-anulada' : '' %>">
                                        
                                        <td><span class="fw-bold text-muted small">#<%= String(v.id).padStart(6, '0') %></span></td>
                                        
                                        <td>
                                            <div class="fw-bold"><%= formatDateShort(v.fecha) %></div>
                                            <small class="text-muted"><%= new Date(v.fecha).toLocaleTimeString('es-PE', {hour:'2-digit', minute:'2-digit'}) %></small>
                                        </td>
                                        
                                        <td>
                                            <i class="bi bi-person"></i> <%= v.cliente_nombre || 'Público General' %>
                                        </td>
                                        
                                        <td>
                                            <% if(v.metodo_pago === 'Efectivo') { %>
                                                <span class="badge" style="background:rgba(107,171,142,0.15); color: #3a6e52; border:1px solid rgba(107,171,142,0.4); border-radius:50px; padding: 0.3em 0.8em;">
                                                    <i class="bi bi-cash"></i> Efectivo
                                                </span>
                                            <% } else if (v.metodo_pago === 'Tarjeta' || v.metodo_pago === '$' || v.metodo_pago === '€') { %>
                                                <span class="badge" style="background:rgba(201,132,122,0.15); color: var(--primary-dark); border:1px solid rgba(201,132,122,0.4); border-radius:50px; padding: 0.3em 0.8em;">
                                                    <i class="bi bi-credit-card"></i> Tarjeta
                                                </span>
                                            <% } else { %>
                                                <span class="badge" style="background:rgba(212,165,116,0.15); color:#7A5C2E; border:1px solid rgba(212,165,116,0.4); border-radius:50px; padding: 0.3em 0.8em;">
                                                    <i class="bi bi-phone"></i> <%= v.metodo_pago %>
                                                </span>
                                            <% } %>
                                        </td>
                                        
                                        <td class="fw-bold fs-6 text-dark"><%= formatCurrency(v.total) %></td>
                                        
                                        <td>
                                            <% if (v.estado === 'completado') { %>
                                                <span class="badge bg-success">Completado</span>
                                            <% } else { %>
                                                <span class="badge bg-danger">ANULADO</span>
                                            <% } %>
                                        </td>
                                        
                                        <td class="text-end">
                                            <a href="/ventas/<%= v.id %>" class="btn btn-sm btn-outline-secondary" title="Ver Recibo"><i class="bi bi-receipt"></i></a>
                                            
                                            <% if (typeof userRol !== 'undefined' && userRol === 'admin' && v.estado !== 'anulado') { %>
                                                <form action="/ventas/anular/<%= v.id %>" method="POST" class="d-inline" 
                                                      onsubmit="return confirm('⚠️ ¿ADVERTENCIA DE SEGURIDAD?\n\nEstás a punto de ANULAR la venta #<%= v.id %>.\n\nConsecuencias:\n1. El dinero se restará de la caja.\n2. Los productos volverán al stock.\n3. Esta acción NO se puede deshacer.\n\n¿Continuar?');">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Anular Venta"><i class="bi bi-x-circle"></i></button>
                                                </form>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-white text-end text-muted small">
                Mostrando <%= ventas.length %> registros
            </div>
        </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>