<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Comprobante #<%= venta.id %> | Boutique System</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/bwip-js@3.0.4/dist/bwip-js-min.js"></script>

    <style>
        body { background-color: #F8F5F5; font-family: 'Inter', sans-serif; }
        .ticket-visual {
            max-width: 380px;
            margin: 40px auto;
            background: white;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            border-radius: 12px;
            border: 1px solid #EEE4E1;
            position: relative;
            overflow: hidden;
        }
        .ticket-visual::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 6px;
            background: linear-gradient(90deg, #C9847A 0%, #9B7FA6 50%, #D4A574 100%);
        }
        .logo-ticket {
            max-width: 110px; height: auto; margin-bottom: 10px;
            display: block; margin-left: auto; margin-right: auto;
        }
        .themed-header {
            background-color: #2B2431;
            padding: 1rem 0;
            border-bottom: 3px solid #C9847A;
        }

        @media print {
            nav, .navbar, .btn, .no-print, .themed-header { display: none !important; }
            @page { margin: 0; size: 80mm auto; }
            body { background: white; margin: 0; padding: 0; width: 80mm; }
            .ticket-visual {
                width: 75mm; max-width: 75mm !important;
                margin: 0; padding: 5px 2px 10px 2px;
                box-shadow: none; border: none; border-radius: 0;
            }
            .ticket-visual::before { display: none; }
            * { font-family: 'Courier New', Courier, monospace !important; color: black !important; font-weight: 600; }
            h4 { font-size: 14px !important; margin-bottom: 5px; font-weight: bold; }
            div, p, span, th, td { font-size: 11px !important; }
            .fw-bold { font-weight: 900 !important; }
            hr { border-top: 1px dashed black !important; opacity: 1; margin: 6px 0; }
            table { width: 100%; margin-bottom: 5px; border-collapse: collapse; }
            th { border-bottom: 1px dashed black; text-align: left; padding-bottom:3px; }
            td { vertical-align: top; padding-top: 3px; }
            .text-end { text-align: right; }
            .logo-ticket { filter: grayscale(100%) contrast(150%); max-width: 80%; }
            canvas { max-width: 90% !important; height: 45px !important; display: block; margin: 8px auto; }
        }
    </style>
</head>
<body>

    <div class="themed-header no-print text-center shadow-sm">
        <div class="container d-flex justify-content-center gap-3">
            <a href="/ventas/nueva" class="btn text-white px-4 fw-bold" style="background:#6BAB8E; border-color:#5c977c; border-radius:8px;"><i class="bi bi-cart-plus me-1"></i> Nueva Venta</a>
            <button onclick="window.print()" class="btn text-white px-4 fw-bold" style="background:#C9847A; border-color:#b5766c; border-radius:8px;"><i class="bi bi-printer me-1"></i> Imprimir Ticket</button>
            <a href="/ventas" class="btn btn-outline-light px-4" style="border-radius:8px;">Volver al Historial</a>
        </div>
    </div>

    <div class="ticket-visual">
        <div class="text-center">
            <% if (typeof shop !== 'undefined' && shop.logo_url) { %>
                <img src="<%= shop.logo_url %>" alt="Logo" class="logo-ticket">
                <div class="fw-bold text-uppercase mt-1" style="font-size: 12px;"><%= shop.nombre_negocio %></div>
            <% } else { %>
                <h4 class="text-uppercase mb-1"><%= typeof shop !== 'undefined' ? shop.nombre_negocio : 'MI BOUTIQUE' %></h4>
            <% } %>

            <% if (typeof shop !== 'undefined' && shop.direccion) { %> <div style="line-height: 1.2;"><%= shop.direccion %></div> <% } %>
            <% if (typeof shop !== 'undefined' && shop.telefono) { %> <div class="mt-1">Tel: <%= shop.telefono %></div> <% } %>
        </div>
            
        <hr>
        
        <div class="d-flex justify-content-between">
            <span>TICKET VENTA</span>
            <span class="fw-bold">#<%= String(venta.id).padStart(6, '0') %></span>
        </div>
        <div class="d-flex justify-content-between">
            <span>Fecha:</span>
            <span><%= formatDateShort(venta.fecha) %> <%= new Date(venta.fecha).toLocaleTimeString('es-PE', {hour: '2-digit', minute:'2-digit'}) %></span>
        </div>

        <hr>

        <div class="mb-1">
            <div>Cli: <strong><%= venta.cliente_nombre || 'Público General' %></strong></div>
            <% if (venta.cliente_documento && venta.cliente_documento !== 'SD') { %> <div>Doc: <%= venta.cliente_documento %></div> <% } %>
        </div>

        <hr>

        <table border="0" cellspacing="0" cellpadding="0">
            <thead>
                <tr>
                    <th style="width: 15%;">Cant</th>
                    <th style="width: 60%;">Descrip.</th>
                    <th class="text-end">Total</th>
                </tr>
            </thead>
            <tbody>
                <% let totalAhorro = 0; %>
                <% venta.items.forEach(item => { %>
                    <% if(item.descuento > 0) totalAhorro += parseFloat(item.descuento); %>
                    <tr>
                        <td style="text-align: center;"><%= item.cantidad %></td>
                        <td>
                            <div class="text-truncate" style="max-width: 125px;"><%= item.producto_nombre %></div>
                            <% if(item.descuento > 0) { %>
                                <div style="font-size: 10px; font-style: italic;">(Desc: -<%= formatCurrency(item.descuento) %>)</div>
                            <% } %>
                        </td>
                        <td class="text-end"><%= (parseFloat(item.subtotal)).toFixed(2) %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

        <hr>

        <div class="d-flex justify-content-between mb-1">
            <span>Pago con:</span>
            <span class="text-uppercase"><%= venta.metodo_pago %></span>
        </div>
        
        <% if (totalAhorro > 0) { %>
            <div class="d-flex justify-content-between mb-1 fw-bold">
                <span>*** AHORRO TOTAL:</span>
                <span><%= formatCurrency(totalAhorro) %> ***</span>
            </div>
        <% } %>

        <div class="d-flex justify-content-between fs-6 mt-2">
            <strong class="fw-bold" style="font-size: 14px;">TOTAL PAGADO:</strong>
            <strong class="fw-bold" style="font-size: 16px;"><%= formatCurrency(venta.total) %></strong>
        </div>

        <hr>

        <div class="text-center mt-2">
            <p class="mb-2 fst-italic"><%= typeof shop !== 'undefined' && shop.mensaje_ticket ? shop.mensaje_ticket : '¡Gracias por su preferencia!' %></p>
            <canvas id="barcode-ticket"></canvas>
            <div style="font-size: 10px;"><%= String(venta.id).padStart(8, '0') %></div>
            <div class="mt-1" style="font-size: 9px;">Sistema Boutique v2.5</div>
        </div>
    </div>

    <script>
        try {
            let ticketID = "<%= String(venta.id).padStart(8, '0') %>";
            bwipjs.toCanvas('barcode-ticket', { bcid: 'code128', text: ticketID, scale: 2, height: 5, includetext: false, textxalign: 'center' });
        } catch (e) { console.error("Error barcode:", e); }
    </script>
</body>
</html>