<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { title: 'POS — Punto de Venta | Boutique' }) %>
    <style>
        /* ─── POS: Layout fijo dentro del main-content ─── */
        .pos-wrapper {
            display: flex;
            height: calc(100vh - 65px); /* altura total menos el top-header */
            overflow: hidden;
            background: var(--bg-main);
        }

        /* ─── ZONA IZQUIERDA: búsqueda + grid ─── */
        .pos-products-panel {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            padding: 1.2rem 1.4rem 1.2rem 1.6rem;
            gap: 1rem;
        }

        /* Barra de herramientas del POS */
        .pos-toolbar {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            flex-shrink: 0;
        }

        .pos-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--text-primary);
            margin: 0;
            white-space: nowrap;
        }

        /* Inputs de búsqueda estilo sistema */
        .pos-input-wrap {
            position: relative;
            flex: 1;
        }
        .pos-input-wrap .pi-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 0.88rem;
            pointer-events: none;
        }
        .pos-input-wrap.search .pi-icon { color: var(--primary); }
        .pos-input-wrap.scanner .pi-icon { color: var(--accent); }
        .pos-input-wrap input {
            width: 100%;
            border: 1px solid #EEE4E1;
            border-radius: 50px;
            padding: 0.5rem 1rem 0.5rem 2.35rem;
            font-size: 0.85rem;
            font-family: 'Inter', sans-serif;
            color: var(--text-primary);
            background: #fff;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .pos-input-wrap input::placeholder { color: var(--text-muted); }
        .pos-input-wrap input:focus {
            border-color: var(--primary-light);
            box-shadow: 0 0 0 0.2rem rgba(201,132,122,0.15);
        }
        .pos-input-wrap.scanner input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 0.2rem rgba(212,165,116,0.18);
        }
        /* Flash verde al escanear */
        .pos-input-wrap.scanner input.scanned {
            border-color: var(--success);
            box-shadow: 0 0 0 0.2rem rgba(107,171,142,0.25);
            animation: scanPulse 0.4s ease;
        }
        @keyframes scanPulse {
            0%   { box-shadow: 0 0 0 0 rgba(107,171,142,0.6); }
            70%  { box-shadow: 0 0 0 10px rgba(107,171,142,0); }
            100% { box-shadow: 0 0 0 0 rgba(107,171,142,0); }
        }

        /* Chip indicador de escáner */
        .scanner-chip {
            display: flex;
            align-items: center;
            gap: 5px;
            background: var(--accent-light);
            color: #7A5C2E;
            font-size: 0.7rem;
            font-weight: 600;
            padding: 4px 10px;
            border-radius: 50px;
            white-space: nowrap;
            border: 1px solid rgba(212,165,116,0.3);
        }

        /* ─── GRID DE PRODUCTOS ─── */
        .pos-grid-wrap {
            flex: 1;
            overflow-y: auto;
            padding-right: 4px;
        }
        .pos-grid-wrap::-webkit-scrollbar { width: 4px; }
        .pos-grid-wrap::-webkit-scrollbar-thumb { background: var(--primary-light); border-radius: 10px; }

        .pos-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(155px, 1fr));
            gap: 0.85rem;
        }

        /* Tarjeta de producto — estilo widget-card del sistema */
        .pos-product-card {
            background: #fff;
            border: 1px solid #EEE4E1;
            border-radius: 14px;
            overflow: hidden;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s;
            box-shadow: 0 2px 10px rgba(61,32,48,0.05);
            position: relative;
            user-select: none;
        }
        .pos-product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 28px rgba(201,132,122,0.18);
            border-color: var(--primary-light);
        }
        .pos-product-card:active { transform: scale(0.97); box-shadow: none; }

        /* Badge stock */
        .pos-stock-badge {
            position: absolute;
            top: 8px; right: 8px;
            font-size: 0.6rem;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 20px;
            background: var(--bg-blush);
            color: var(--text-muted);
            letter-spacing: 0.3px;
            z-index: 2;
        }
        .pos-stock-badge.low  { background: rgba(212,165,116,0.18); color: #7A5C2E; }
        .pos-stock-badge.out  { background: rgba(192,97,111,0.15); color: var(--danger); }

        .pos-img-zone {
            height: 112px;
            background: linear-gradient(145deg, #FBF7F5 0%, #F8EFF2 100%);
            display: flex; align-items: center; justify-content: center;
            padding: 10px;
        }
        .pos-img-zone img { max-height: 92%; max-width: 92%; object-fit: contain; }
        .pos-img-zone .no-img { font-size: 2.6rem; color: var(--primary-light); opacity: 0.7; }

        .pos-card-body {
            padding: 0.6rem 0.75rem 0.75rem;
            text-align: center;
        }
        .pos-prod-name {
            font-size: 0.78rem;
            font-weight: 600;
            color: var(--text-primary);
            line-height: 1.3;
            margin-bottom: 5px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            min-height: 2.1em;
        }
        .pos-prod-price {
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--primary);
            font-family: 'Inter', sans-serif;
        }

        /* ─── PANEL DERECHO: CARRITO ─── */
        .pos-cart-panel {
            width: 350px;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            background: #fff;
            border-left: 1px solid #EEE4E1;
            box-shadow: -2px 0 16px rgba(61,32,48,0.05);
        }

        /* Header del carrito — gradiente bordeaux como widget-header-dark */
        .pos-cart-header {
            background: linear-gradient(135deg, #2E1F29 0%, #3D2B35 100%);
            padding: 1rem 1.25rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
        }
        .pos-cart-title {
            font-family: 'Playfair Display', serif;
            color: var(--primary-light);
            font-size: 0.95rem;
            font-weight: 700;
            letter-spacing: 0.8px;
            display: flex; align-items: center; gap: 8px;
        }
        .pos-cart-badge {
            background: rgba(201,132,122,0.25);
            color: var(--primary-light);
            font-size: 0.7rem;
            font-weight: 700;
            padding: 2px 9px;
            border-radius: 20px;
            font-family: 'Inter', sans-serif;
        }

        /* Selector de cliente */
        .pos-client-bar {
            padding: 0.75rem 1.1rem;
            border-bottom: 1px solid #F5EBF0;
            flex-shrink: 0;
        }
        .pos-client-bar .form-label {
            font-size: 0.68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
            margin-bottom: 5px;
        }
        .pos-client-bar .form-select {
            font-size: 0.82rem;
            border: 1px solid #EEE4E1;
            border-radius: 10px;
            color: var(--text-primary);
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%239E8A96' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
        }
        .pos-client-bar .form-select:focus {
            border-color: var(--primary-light);
            box-shadow: 0 0 0 0.2rem rgba(201,132,122,0.15);
        }

        /* Área ítems del carrito */
        .pos-cart-items {
            flex: 1;
            overflow-y: auto;
        }
        .pos-cart-items::-webkit-scrollbar { width: 4px; }
        .pos-cart-items::-webkit-scrollbar-thumb { background: var(--primary-light); border-radius: 10px; }

        /* Estado vacío */
        .pos-cart-empty {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            padding: 2rem;
            text-align: center;
        }
        .pos-cart-empty .empty-icon {
            width: 64px; height: 64px;
            border-radius: 50%;
            background: var(--bg-blush);
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 1rem;
        }
        .pos-cart-empty .empty-icon i {
            font-size: 1.8rem;
            color: var(--primary-light);
        }
        .pos-cart-empty p {
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-muted);
            margin: 0;
        }
        .pos-cart-empty small {
            color: var(--text-muted);
            font-size: 0.7rem;
            margin-top: 6px;
            display: block;
            opacity: 0.7;
        }

        /* Fila de ítem */
        .pos-cart-row {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 0.7rem 1.1rem;
            border-bottom: 1px solid #F8EFF2;
            transition: background 0.15s;
        }
        .pos-cart-row:hover { background: #FDF5F7; }
        .pos-cart-row:last-child { border-bottom: none; }

        .ci-thumb {
            width: 42px; height: 42px;
            border-radius: 10px;
            background: var(--bg-blush);
            border: 1px solid #EEE4E1;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
            overflow: hidden;
        }
        .ci-thumb img { width: 100%; height: 100%; object-fit: contain; }
        .ci-thumb i { font-size: 1.2rem; color: var(--primary-light); }

        .ci-info { flex: 1; min-width: 0; }
        .ci-name {
            font-size: 0.78rem;
            font-weight: 600;
            color: var(--text-primary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-bottom: 1px;
        }
        .ci-unit-price { font-size: 0.67rem; color: var(--text-muted); }

        /* Controles de cantidad */
        .ci-qty-row {
            display: flex;
            align-items: center;
            gap: 4px;
            margin-top: 5px;
        }
        .ci-qty-btn {
            width: 22px; height: 22px;
            border-radius: 6px;
            border: 1px solid #EEE4E1;
            background: transparent;
            color: var(--text-primary);
            font-size: 0.75rem;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer;
            transition: all 0.15s;
            line-height: 1;
        }
        .ci-qty-btn:hover {
            background: var(--primary);
            border-color: var(--primary);
            color: #fff;
        }
        .ci-qty-val {
            font-size: 0.8rem;
            font-weight: 700;
            min-width: 20px;
            text-align: center;
            color: var(--text-primary);
        }
        /* Input descuento inline */
        .ci-disc-wrap {
            display: flex;
            align-items: center;
            gap: 4px;
            margin-top: 4px;
        }
        .ci-disc-label { font-size: 0.62rem; color: var(--text-muted); }
        .ci-disc-input {
            width: 54px;
            border: 1px solid #EEE4E1;
            border-radius: 6px;
            padding: 1px 5px;
            font-size: 0.72rem;
            color: var(--danger);
            text-align: center;
            outline: none;
            transition: border-color 0.15s;
        }
        .ci-disc-input:focus { border-color: var(--primary-light); }

        .ci-subtotal {
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--primary);
            white-space: nowrap;
            align-self: center;
        }
        .ci-remove {
            color: #DDD;
            font-size: 1rem;
            cursor: pointer;
            align-self: flex-start;
            margin-top: 2px;
            transition: color 0.15s;
        }
        .ci-remove:hover { color: var(--danger); }

        /* ─── FOOTER DEL CARRITO ─── */
        .pos-cart-footer {
            border-top: 2px solid #F0E8EE;
            padding: 1.1rem 1.25rem 1.2rem;
            flex-shrink: 0;
            background: #fff;
        }

        /* Separador decorativo mini */
        .cart-mini-divider {
            height: 1px;
            background: linear-gradient(90deg, var(--primary-light) 0%, transparent 100%);
            margin: 0.85rem 0 0.9rem;
            opacity: 0.6;
        }

        /* Total */
        .pos-total-row {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            margin-bottom: 0.9rem;
        }
        .pos-total-label {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-muted);
        }
        .pos-total-amount {
            font-family: 'Playfair Display', serif;
            font-size: 1.7rem;
            font-weight: 700;
            color: var(--primary);
            line-height: 1;
        }

        /* Métodos de pago */
        .pos-payment-grid {
            display: flex;
            gap: 6px;
            margin-bottom: 0.85rem;
        }
        .pos-payment-grid .btn-check + label {
            flex: 1;
            text-align: center;
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-radius: 10px;
            border: 1.5px solid #EEE4E1;
            color: var(--text-muted);
            padding: 0.5rem 0.3rem;
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
        }
        .pos-payment-grid .btn-check:checked + label {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            border-color: var(--primary);
            color: #fff;
            box-shadow: 0 3px 10px rgba(201,132,122,0.3);
        }
        .pos-payment-grid .btn-check + label:hover {
            border-color: var(--primary-light);
            color: var(--primary);
        }

        /* Botón cobrar */
        .btn-pos-cobrar {
            width: 100%;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            border: none;
            border-radius: 12px;
            padding: 0.9rem 1rem;
            font-family: 'Inter', sans-serif;
            font-size: 0.9rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: all 0.25s;
            box-shadow: 0 4px 16px rgba(201,132,122,0.35);
        }
        .btn-pos-cobrar:not(:disabled):hover {
            background: linear-gradient(135deg, var(--primary-dark) 0%, #8A4D46 100%);
            box-shadow: 0 6px 22px rgba(201,132,122,0.5);
            transform: translateY(-1px);
        }
        .btn-pos-cobrar:disabled {
            background: #E0D5D8;
            box-shadow: none;
            cursor: not-allowed;
            color: rgba(255,255,255,0.6);
        }
        .btn-pos-cobrar:active { transform: translateY(0); }
        .btn-cobrar-sub {
            font-size: 0.7rem;
            font-weight: 400;
            opacity: 0.82;
            display: block;
            text-transform: none;
            letter-spacing: 0.2px;
            margin-top: 2px;
        }

        /* Atajos de teclado */
        .pos-shortcuts {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-top: 8px;
        }
        .pos-shortcut {
            font-size: 0.63rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 3px;
        }
        .pos-shortcut kbd {
            background: var(--bg-blush);
            border: 1px solid #EEE4E1;
            border-radius: 4px;
            padding: 1px 5px;
            font-size: 0.62rem;
            font-family: 'Inter', sans-serif;
            color: var(--text-muted);
        }

        /* ─── TOAST BOUTIQUE ─── */
        #posToastContainer {
            position: fixed;
            top: 80px;
            right: 20px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 8px;
            min-width: 290px;
            max-width: 340px;
        }
        .pos-toast {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0.8rem 1rem;
            border-radius: 12px;
            font-size: 0.82rem;
            font-weight: 600;
            color: #fff;
            box-shadow: 0 6px 24px rgba(0,0,0,0.18);
            animation: toastIn 0.28s ease;
            font-family: 'Inter', sans-serif;
        }
        .pos-toast.success { background: linear-gradient(135deg, var(--success) 0%, #4e9574 100%); }
        .pos-toast.error   { background: linear-gradient(135deg, var(--danger)  0%, #a34d5a 100%); }
        .pos-toast.warning { background: linear-gradient(135deg, var(--accent)  0%, #b8884e 100%); }
        .pos-toast i { font-size: 1.05rem; flex-shrink: 0; }
        @keyframes toastIn  { from { opacity:0; transform:translateX(22px); } to { opacity:1; transform:translateX(0); } }
        @keyframes toastOut { from { opacity:1; transform:translateX(0); } to { opacity:0; transform:translateX(22px); } }
    </style>
</head>
<body>
<div class="dashboard-wrapper">
    <%- include('../partials/sidebar') %>

    <main class="main-content" style="display:flex;flex-direction:column;overflow:hidden;">
        <!-- TOP HEADER personalizado para POS -->
        <header class="top-header" style="flex-shrink:0;">
            <div class="d-flex align-items-center gap-3">
                <!-- Enlace de regreso -->
                <a href="/" class="d-flex align-items-center gap-1 text-decoration-none" style="color:var(--text-muted);font-size:0.82rem;font-weight:600;">
                    <i class="bi bi-chevron-left"></i> Dashboard
                </a>
                <div style="width:1px;height:18px;background:#EEE4E1;"></div>
                <h1 class="module-title mb-0" style="font-size:1.1rem;">
                    <i class="bi bi-bag-check module-title-icon me-1"></i>
                    Punto de Venta
                </h1>
            </div>

            <div class="d-flex align-items-center gap-2">
                <!-- Buscador de texto -->
                <div class="pos-input-wrap search" style="width:240px;">
                    <i class="bi bi-search pi-icon"></i>
                    <input type="text" id="buscadorProducto"
                           placeholder="Buscar producto..."
                           oninput="filtrarProductos()"
                           autocomplete="off">
                </div>

                <!-- Campo escáner -->
                <div class="pos-input-wrap scanner" style="width:210px;">
                    <i class="bi bi-upc-scan pi-icon"></i>
                    <input type="text" id="scannerInput"
                           placeholder="Escanear código..."
                           autocomplete="off"
                           inputmode="none">
                </div>

                <!-- Chip de estado del escáner -->
                <span class="scanner-chip">
                    <i class="bi bi-lightning-charge-fill"></i> Escáner listo
                </span>

                <!-- Botones del sistema -->
                <% if (locals.cajaAbierta) { %>
                <a href="/caja/cierre" class="btn btn-boutique btn-sm">
                    <i class="bi bi-lock-fill me-1"></i> Cerrar Caja
                </a>
                <% } else { %>
                <a href="/caja/apertura" class="btn btn-outline-rose btn-sm">
                    <i class="bi bi-wallet2 me-1"></i> Abrir Caja
                </a>
                <% } %>
                <a href="/logout" class="btn btn-sm" style="background-color:#F8EFF2;color:var(--text-primary);border:1px solid #EEE4E1;">
                    <i class="bi bi-box-arrow-right"></i>
                </a>
            </div>
        </header>

        <!-- CUERPO DEL POS -->
        <div class="pos-wrapper">

            <!-- ===== GRILLA DE PRODUCTOS ===== -->
            <div class="pos-products-panel">
                <div class="pos-grid-wrap">
                    <div class="pos-grid" id="gridProductos">
                        <% productos.forEach(p => { %>
                        <div class="producto-card-container"
                             data-nombre="<%= p.nombre.toLowerCase() %>"
                             data-codigo="<%= p.codigo_barras ? p.codigo_barras.toLowerCase() : '' %>">
                            <div class="pos-product-card"
                                 onclick="agregarAlCarrito(<%= p.id %>, '<%= p.nombre.replace(/'/g,"\\'") %>', <%= p.precio_venta %>, <%= p.stock_actual %>, '<%= p.imagen_url || '' %>')">

                                <span class="pos-stock-badge <%= p.stock_actual === 0 ? 'out' : (p.stock_actual <= 3 ? 'low' : '') %>">
                                    <%= p.stock_actual === 0 ? 'Sin stock' : (p.stock_actual <= 3 ? '¡Últimas ' + p.stock_actual + '!' : 'Stock: ' + p.stock_actual) %>
                                </span>

                                <div class="pos-img-zone">
                                    <% if (p.imagen_url) { %>
                                        <img src="<%= p.imagen_url %>" alt="<%= p.nombre %>">
                                    <% } else { %>
                                        <i class="bi bi-bag-heart no-img"></i>
                                    <% } %>
                                </div>

                                <div class="pos-card-body">
                                    <div class="pos-prod-name"><%= p.nombre %></div>
                                    <div class="pos-prod-price"><%= shop.moneda %> <%= parseFloat(p.precio_venta).toFixed(2) %></div>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                </div>
            </div>

            <!-- ===== PANEL DE CARRITO ===== -->
            <div class="pos-cart-panel">

                <!-- Header carrito -->
                <div class="pos-cart-header">
                    <div class="pos-cart-title">
                        <i class="bi bi-bag-check"></i> Carrito
                    </div>
                    <span class="pos-cart-badge" id="cartCountPill">0 ítems</span>
                </div>

                <!-- Selector de cliente -->
                <div class="pos-client-bar">
                    <label class="form-label"><i class="bi bi-person me-1"></i>Cliente</label>
                    <select id="selectCliente" class="form-select form-select-sm">
                        <option value="">— Seleccionar cliente —</option>
                        <% clientes.forEach(c => { %>
                        <option value="<%= c.id %>"><%= c.nombre %></option>
                        <% }) %>
                    </select>
                </div>

                <!-- Ítems -->
                <div class="pos-cart-items" id="posCartItems">
                    <div class="pos-cart-empty" id="emptyCartMsg">
                        <div class="empty-icon">
                            <i class="bi bi-bag"></i>
                        </div>
                        <p>Carrito vacío</p>
                        <small>Haz clic en un producto<br>o escanea un código</small>
                    </div>
                    <div id="tablaProductos"></div>
                </div>

                <!-- Footer -->
                <div class="pos-cart-footer">
                    <div class="cart-mini-divider"></div>

                    <div class="pos-total-row">
                        <span class="pos-total-label">Total a pagar</span>
                        <span class="pos-total-amount"><%= shop.moneda %> <span id="totalVenta">0.00</span></span>
                    </div>

                    <!-- Métodos de pago -->
                    <div class="pos-payment-grid">
                        <input type="radio" class="btn-check" name="metodoPago" id="p1" value="Efectivo" checked>
                        <label for="p1"><i class="bi bi-cash-stack d-block mb-1" style="font-size:1rem;"></i>Efectivo</label>

                        <input type="radio" class="btn-check" name="metodoPago" id="p2" value="Yape">
                        <label for="p2"><i class="bi bi-phone d-block mb-1" style="font-size:1rem;"></i>Yape</label>

                        <input type="radio" class="btn-check" name="metodoPago" id="p3" value="Tarjeta">
                        <label for="p3"><i class="bi bi-credit-card d-block mb-1" style="font-size:1rem;"></i>Tarjeta</label>
                    </div>

                    <button id="btnFinalizar" class="btn-pos-cobrar" onclick="procesarVenta()" disabled>
                        <i class="bi bi-bag-check-fill me-2"></i>Cobrar Pedido
                        <span class="btn-cobrar-sub" id="btnTotal"></span>
                    </button>

                    <div class="pos-shortcuts">
                        <span class="pos-shortcut"><kbd>F2</kbd>Buscar</span>
                        <span class="pos-shortcut"><kbd>F3</kbd>Escáner</span>
                        <span class="pos-shortcut"><kbd>F9</kbd>Cobrar</span>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- Toast container -->
<div id="posToastContainer"></div>

<script>
    const listaGlobalProductos = <%- JSON.stringify(productos) %>;
    const SHOP_MONEDA = "<%= shop.moneda %>";
</script>
<script src="/js/pos.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>