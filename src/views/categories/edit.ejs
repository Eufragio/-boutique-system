<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { title: 'Editar Categoría | Boutique Panel' }) %>
</head>
<body>

    <div class="dashboard-wrapper">
        <%- include('../partials/sidebar') %>

        <main class="main-content">
            <%- include('../partials/top_header') %>

            <div class="container-fluid px-4 pb-5 mt-4">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div>
                        <h2 class="module-title mb-1">
                            <i class="bi bi-pencil-square module-title-icon"></i>
                            Editar Categoría
                        </h2>
                        <p class="text-muted small mb-0" style="font-family:'Inter',sans-serif; padding-left:2px;">
                            Modificar el nombre de la categoría actual
                        </p>
                    </div>
                    <a href="/categorias" class="btn btn-outline-secondary btn-sm" style="border-radius:8px;">
                        <i class="bi bi-arrow-left me-1"></i> Volver
                    </a>
                </div>

                <hr class="boutique-divider mb-4">

                <div class="row justify-content-center">
                    <div class="col-md-6 col-lg-5">
                        <div class="widget-card h-100">
                            <div class="widget-header-accent d-flex align-items-center gap-2" style="border-radius:16px 16px 0 0;">
                                <i class="bi bi-tag-fill"></i>
                                <span class="fw-semibold" style="font-family:'Inter',sans-serif; letter-spacing:.5px;">Datos de la Categoría</span>
                            </div>
                            <div class="card-body p-4">
                                <form action="/categorias/editar/<%= categoria.id %>" method="POST">
                                    <div class="mb-4">
                                        <label class="form-label text-muted small fw-bold text-uppercase">Nombre</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-card-text text-muted"></i></span>
                                            <input type="text" name="nombre" class="form-control border-start-0 ps-0" value="<%= categoria.nombre %>" required autocomplete="off">
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-end gap-2 mt-4">
                                        <a href="/categorias" class="btn btn-light border px-4" style="border-radius:10px;">Cancelar</a>
                                        <button type="submit" class="btn btn-boutique px-4 py-2 shadow-sm" style="border-radius:10px;">
                                            <i class="bi bi-check2-circle me-1"></i> Actualizar
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>