<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { title: 'Categorías | Boutique Panel' }) %>
</head>
<body>
    <div class="dashboard-wrapper">
        <%- include('../partials/sidebar') %>
        
        <main class="main-content">
            <%- include('../partials/top_header') %>

            <div class="container-fluid px-4 pb-5 mt-4">
        
                <!-- Alertas -->
                <% if (success_msg && success_msg.length > 0) { %>
                    <div class="alert alert-boutique-success alert-dismissible fade show d-flex align-items-center gap-2 mb-4">
                        <i class="bi bi-check-circle-fill fs-5"></i>
                        <span><%= success_msg %></span>
                        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>

                <!-- Encabezado de página -->
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div>
                        <h2 class="module-title mb-1">
                            <i class="bi bi-tags module-title-icon"></i>
                            Gestión de Categorías
                        </h2>
                        <p class="text-muted small mb-0" style="font-family:'Inter',sans-serif; padding-left:2px;">
                            Organiza tu catálogo de productos por secciones
                        </p>
                    </div>
                </div>

                <hr class="boutique-divider mb-4">

                <div class="row g-4">
                    <!-- Formulario de Creación (Izquierda) -->
                    <div class="col-md-4">
                        <div class="widget-card h-100">
                            <div class="widget-header-dark d-flex align-items-center gap-2" style="border-radius:16px 16px 0 0;">
                                <i class="bi bi-plus-circle"></i>
                                <span class="fw-semibold" style="font-family:'Inter',sans-serif; letter-spacing:.5px;">Nueva Categoría</span>
                            </div>
                            <div class="card-body p-4">
                                <form action="/categorias" method="POST">
                                    <div class="mb-4">
                                        <label class="form-label" style="font-size:0.85rem; font-weight:600; color:var(--text-primary);">Nombre de la Categoría</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-tag text-muted"></i></span>
                                            <input type="text" name="nombre" class="form-control border-start-0 ps-0" placeholder="Ej: Vestidos de Gala" required autocomplete="off">
                                        </div>
                                    </div>
                                    <button type="submit" class="btn btn-boutique w-100 py-2 shadow-sm rounded-3">
                                        <i class="bi bi-save2 me-1"></i> Guardar Categoría
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Listado de Categorías (Derecha) -->
                    <div class="col-md-8">
                        <div class="widget-card h-100">
                            <div class="widget-header-accent d-flex align-items-center gap-2" style="border-radius:16px 16px 0 0; padding:1rem 1.5rem; text-align:left; text-transform:none; font-size:0.95rem; font-weight:600;">
                                <i class="bi bi-list-ul"></i>
                                <span style="font-family:'Inter',sans-serif;">Listado de Categorías</span>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table boutique-table mb-0 align-middle">
                                        <thead>
                                            <tr>
                                                <th class="ps-4" style="width: 80px;">ID</th>
                                                <th>Nombre</th>
                                                <th class="text-center">Estado</th>
                                                <th class="text-end pe-4">Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% categorias.forEach(c => { %>
                                                <tr>
                                                    <td class="ps-4 fw-bold text-muted">#<%= String(c.id).padStart(3, '0') %></td>
                                                    <td class="fw-bold" style="color:var(--text-primary);"><%= c.nombre %></td>
                                                    <td class="text-center">
                                                        <% if(c.activo) { %>
                                                            <span class="badge badge-success rounded-pill px-3 py-2">
                                                                <i class="bi bi-circle-fill me-1" style="font-size:0.4rem; vertical-align:middle;"></i> Activo
                                                            </span>
                                                        <% } else { %>
                                                            <span class="badge rounded-pill bg-light text-muted border px-3 py-2">
                                                                <i class="bi bi-circle-fill me-1" style="font-size:0.4rem; vertical-align:middle;"></i> Inactivo
                                                            </span>
                                                        <% } %>
                                                    </td>
                                                    <td class="text-end pe-4">
                                                        <div class="btn-group shadow-sm">
                                                            <a href="/categorias/editar/<%= c.id %>" class="btn btn-outline-rose btn-sm" title="Editar Categoría">
                                                                <i class="bi bi-pencil"></i>
                                                            </a>
                                                            <form action="/categorias/estado/<%= c.id %>" method="POST" class="d-inline" style="margin:0;">
                                                                <% if(c.activo) { %>
                                                                    <button class="btn btn-outline-secondary btn-sm" title="Desactivar" style="border-top-left-radius:0; border-bottom-left-radius:0;">
                                                                        <i class="bi bi-slash-circle"></i>
                                                                    </button>
                                                                <% } else { %>
                                                                    <button class="btn btn-outline-success btn-sm" title="Activar" style="border-top-left-radius:0; border-bottom-left-radius:0;">
                                                                        <i class="bi bi-check-lg"></i>
                                                                    </button>
                                                                <% } %>
                                                            </form>
                                                        </div>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                            <% if(categorias.length === 0) { %>
                                                <tr>
                                                    <td colspan="4" class="text-center py-5 text-muted">
                                                        <i class="bi bi-inboxes ds-3 d-block mb-2" style="font-size:2rem;opacity:0.5;"></i>
                                                        No hay categorías registradas
                                                    </td>
                                                </tr>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </main>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>