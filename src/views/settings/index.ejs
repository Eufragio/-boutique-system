<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { title: 'Configuración | Boutique Panel' }) %>
</head>
<body>
    <div class="dashboard-wrapper">
        <%- include('../partials/sidebar') %>

        <main class="main-content">
            <%- include('../partials/top_header') %>

            <div class="container-fluid px-4 pb-5 mt-4">

                <!-- Alertas -->
                <% if (success_msg && success_msg.length > 0) { %>
                <div class="alert alert-boutique-success alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert">
                    <i class="bi bi-check-circle-fill fs-5"></i>
                    <span><%= success_msg %></span>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
                <% } %>
                <% if (error_msg && error_msg.length > 0) { %>
                <div class="alert alert-boutique-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                    <span><%= error_msg %></span>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
                <% } %>

                <!-- Encabezado de página -->
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div>
                        <h2 class="module-title mb-1">
                            <i class="bi bi-gear-wide-connected module-title-icon"></i>
                            Configuración del Sistema
                        </h2>
                        <p class="text-muted small mb-0" style="font-family:'Inter',sans-serif; padding-left:2px;">
                            Personaliza los datos y preferencias de tu boutique
                        </p>
                    </div>
                </div>

                <!-- Separador decorativo -->
                <hr class="boutique-divider mb-4">

                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <form action="/configuracion" method="POST" enctype="multipart/form-data">

                            <!-- ====== LOGO ====== -->
                            <div class="widget-card mb-4">
                                <div class="widget-header-dark d-flex align-items-center gap-2" style="border-radius:16px 16px 0 0;">
                                    <i class="bi bi-image text-white" style="font-size:1.1rem;"></i>
                                    <span class="fw-semibold" style="font-family:'Inter',sans-serif; letter-spacing:.5px;">Logo de la Tienda</span>
                                </div>
                                <div class="card-body p-4 text-center">
                                    <div class="mb-3 position-relative d-inline-block">
                                        <% if (config.logo_url) { %>
                                            <img id="logoPreview" src="<%= config.logo_url %>"
                                                 alt="Logo actual"
                                                 class="rounded-3 shadow-sm"
                                                 style="width:160px;height:160px;object-fit:contain;background:#fff;border:2px solid #EEE4E1;">
                                        <% } else { %>
                                            <div id="logoPlaceholder"
                                                 class="d-inline-flex align-items-center justify-content-center rounded-3 shadow-sm"
                                                 style="width:160px;height:160px;background:#FBF7F5;border:2px dashed #F0C4BE;">
                                                <div class="text-center">
                                                    <i class="bi bi-bag-heart" style="font-size:3rem;color:var(--primary-light);"></i>
                                                    <p class="small mt-2 mb-0" style="color:var(--text-muted);">Sin logo</p>
                                                </div>
                                            </div>
                                            <img id="logoPreview" src="#"
                                                 style="display:none;width:160px;height:160px;object-fit:contain;"
                                                 class="rounded-3 shadow-sm">
                                        <% } %>
                                    </div>
                                    <br>
                                    <label class="btn btn-outline-rose btn-sm mt-2 cursor-pointer">
                                        <i class="bi bi-cloud-upload me-1"></i> Subir / Cambiar Logo
                                        <input type="file" name="logo" style="display:none;"
                                               accept="image/png,image/jpeg,image/jpg"
                                               onchange="previewImage(this)">
                                    </label>
                                    <p class="form-text mt-2 small" style="color:var(--text-muted);">
                                        Formato recomendado: Cuadrado (JPG/PNG). Máx 2MB.
                                    </p>
                                </div>
                            </div>

                            <!-- ====== DATOS DE LA TIENDA ====== -->
                            <div class="widget-card mb-4">
                                <div class="widget-header-primary d-flex align-items-center gap-2" style="border-radius:16px 16px 0 0;">
                                    <i class="bi bi-shop"></i>
                                    <span class="fw-semibold" style="font-family:'Inter',sans-serif; letter-spacing:.5px;">Datos de la Tienda</span>
                                </div>
                                <div class="card-body p-4">
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label">Nombre del Negocio</label>
                                            <input type="text" name="nombre" class="form-control"
                                                   value="<%= config.nombre_negocio %>" required
                                                   placeholder="Ej: Mi Boutique">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Teléfono / WhatsApp</label>
                                            <input type="text" name="telefono" class="form-control"
                                                   value="<%= config.telefono %>"
                                                   placeholder="Ej: 999-999-999">
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Dirección Física</label>
                                            <input type="text" name="direccion" class="form-control"
                                                   value="<%= config.direccion %>"
                                                   placeholder="Av. Principal 123">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- ====== AJUSTES REGIONALES ====== -->
                            <div class="widget-card mb-4">
                                <div class="widget-header-accent d-flex align-items-center gap-2" style="border-radius:16px 16px 0 0; padding:1rem 1.5rem; text-align:left; text-transform:none; font-size:0.9rem; font-weight:600; letter-spacing:.5px;">
                                    <i class="bi bi-sliders"></i>
                                    <span style="font-family:'Inter',sans-serif;">Ajustes Regionales</span>
                                </div>
                                <div class="card-body p-4">
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label">Moneda del Sistema</label>
                                            <select name="moneda" class="form-select">
                                                <option value="S/" <%= config.moneda === 'S/' ? 'selected' : '' %>>S/ (Perú - Soles PEN)</option>
                                                <option value="$" <%= config.moneda === '$' ? 'selected' : '' %>>$ (Estados Unidos - Dólares USD)</option>
                                                <option value="€" <%= config.moneda === '€' ? 'selected' : '' %>>€ (España/Europa - Euros EUR)</option>
                                                <option value="Mex$" <%= config.moneda === 'Mex$' ? 'selected' : '' %>>Mex$ (México - Pesos MXN)</option>
                                                <option value="COP$" <%= config.moneda === 'COP$' ? 'selected' : '' %>>COP$ (Colombia - Pesos COP)</option>
                                                <option value="ARS$" <%= config.moneda === 'ARS$' ? 'selected' : '' %>>ARS$ (Argentina - Pesos ARS)</option>
                                                <option value="CLP$" <%= config.moneda === 'CLP$' ? 'selected' : '' %>>CLP$ (Chile - Pesos CLP)</option>
                                                <option value="Bs" <%= config.moneda === 'Bs' ? 'selected' : '' %>>Bs (Bolivia - Bolivianos BOB)</option>
                                                <option value="R$" <%= config.moneda === 'R$' ? 'selected' : '' %>>R$ (Brasil - Reales BRL)</option>
                                                <option value="Gs" <%= config.moneda === 'Gs' ? 'selected' : '' %>>Gs (Paraguay - Guaraníes PYG)</option>
                                                <option value="UYU$" <%= config.moneda === 'UYU$' ? 'selected' : '' %>>UYU$ (Uruguay - Pesos UYU)</option>
                                                <option value="VES" <%= config.moneda === 'VES' ? 'selected' : '' %>>VES (Venezuela - Bolívares VES)</option>
                                                <option value="Q" <%= config.moneda === 'Q' ? 'selected' : '' %>>Q (Guatemala - Quetzales GTQ)</option>
                                                <option value="L" <%= config.moneda === 'L' ? 'selected' : '' %>>L (Honduras - Lempiras HNL)</option>
                                                <option value="C$" <%= config.moneda === 'C$' ? 'selected' : '' %>>C$ (Nicaragua - Córdobas NIO)</option>
                                                <option value="₡" <%= config.moneda === '₡' ? 'selected' : '' %>>₡ (Costa Rica - Colones CRC)</option>
                                                <option value="B/." <%= config.moneda === 'B/.' ? 'selected' : '' %>>B/. (Panamá - Balboas PAB)</option>
                                                <option value="RD$" <%= config.moneda === 'RD$' ? 'selected' : '' %>>RD$ (Rep. Dominicana - Pesos DOP)</option>
                                                <option value="£" <%= config.moneda === '£' ? 'selected' : '' %>>£ (Reino Unido - Libras GBP)</option>
                                            </select>
                                            <div class="form-text" style="color:var(--text-muted);">Símbolo para precios y reportes.</div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Zona Horaria</label>
                                            <select name="zona_horaria" class="form-select">
                                                <option value="America/Lima"                       <%= config.zona_horaria === 'America/Lima'                       ? 'selected' : '' %>>Perú (Lima)</option>
                                                <option value="America/Bogota"                     <%= config.zona_horaria === 'America/Bogota'                     ? 'selected' : '' %>>Colombia</option>
                                                <option value="America/Mexico_City"                <%= config.zona_horaria === 'America/Mexico_City'                ? 'selected' : '' %>>México</option>
                                                <option value="America/Santiago"                   <%= config.zona_horaria === 'America/Santiago'                   ? 'selected' : '' %>>Chile</option>
                                                <option value="America/Argentina/Buenos_Aires"     <%= config.zona_horaria === 'America/Argentina/Buenos_Aires'     ? 'selected' : '' %>>Argentina</option>
                                            </select>
                                            <div class="form-text" style="color:var(--text-muted);">Para el registro correcto de fechas.</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- ====== PIE DE PÁGINA DEL TICKET ====== -->
                            <div class="widget-card mb-4">
                                <div class="module-card-header" style="border-radius:16px 16px 0 0;">
                                    <h6 class="module-title" style="font-size:1rem;">
                                        <i class="bi bi-receipt module-title-icon"></i>
                                        Pie de Página del Ticket
                                    </h6>
                                </div>
                                <div class="card-body p-4">
                                    <label class="form-label">Mensaje de cierre del ticket de venta</label>
                                    <textarea name="mensaje" class="form-control" rows="3"
                                              placeholder="Ej: ¡Gracias por su compra! No se aceptan devoluciones."><%= config.mensaje_ticket %></textarea>
                                    <div class="form-text mt-1" style="color:var(--text-muted);">
                                        Este texto aparecerá al final de cada ticket impreso.
                                    </div>
                                </div>
                            </div>

                            <!-- ====== BOTÓN GUARDAR ====== -->
                            <div class="d-grid gap-2 mt-2 mb-5">
                                <button type="submit" class="btn btn-boutique btn-lg" style="border-radius:12px; letter-spacing:.5px;">
                                    <i class="bi bi-save2 me-2"></i> Guardar Configuración
                                </button>
                            </div>

                        </form>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function previewImage(input) {
            const preview     = document.getElementById('logoPreview');
            const placeholder = document.getElementById('logoPlaceholder');

            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.style.display = 'inline-block';
                    if (placeholder) placeholder.style.display = 'none';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
</body>
</html>